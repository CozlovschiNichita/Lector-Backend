# ==========================================
# LECTOR SERVER - ENVIRONMENT CONFIGURATION
# ==========================================

# --- Database Setup (PostgreSQL via Docker) ---
DB_HOST=127.0.0.1
DB_USERNAME=vapor_username
DB_PASSWORD=your_db_password_here
DB_NAME=lector_database

# --- Security & Authentication ---
# Generate using terminal: openssl rand -base64 32
JWT_SECRET=your_random_secret_here

# --- External Services ---
# Resend API for Email Delivery (Forgot Password)
# Get key at: https://resend.com
RESEND_API_KEY=re_your_resend_key_here

# Ollama local server for AI Summarization
# Default local URL is http://127.0.0.1:11434/api/generate
OLLAMA_URL=http://127.0.0.1:11434/api/generate